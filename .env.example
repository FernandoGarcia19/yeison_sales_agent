# Example .env file for Yeison Sales Agent

# App Configuration
APP_NAME=Yeison Sales Agent
VERSION=1.0.0
DEBUG=true

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/yeison_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# Twilio/WhatsApp Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+14155238886
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=500

# OpenRouter Configuration (for testing - compatible with OpenAI SDK)
USE_OPENROUTER=false
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# Main Backend API (for mutations)
BACKEND_API_URL=http://localhost:3000/api
BACKEND_API_KEY=your_backend_api_key_here
BACKEND_API_TIMEOUT=30
